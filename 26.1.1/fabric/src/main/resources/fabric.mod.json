{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://github.com/${mod_author}",
        "sources": "https://github.com/${mod_author}/${mod_id}"
    },
    "license": "${license}",
    "icon": "icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            "com.iamkaf.torchtoss.TorchTossFabric"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "konfig": "*",
        "minecraft": "${fabric_version_range}",
        "java": ">=${java_version}",
        "amber": ">=${amber_version}"
    },
    "suggests": {
        "modmenu": ">=${mod_menu_version}"
    }
}
  
